# Copy to .env.local and fill values. Step-by-step: docs/GETTING_STARTED.md
#
# Supabase — Project Settings → API
# These are the same values shown as "Project URL" (SUPABASE_URL) and
# "anon public" key (SUPABASE_ANON_KEY) in the Supabase dashboard.
# The NEXT_PUBLIC_ prefix is required so the browser client can read them in Next.js.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Same origin you use in the browser (no trailing slash). Edge Functions need this
# secret set in Supabase Dashboard → Edge Functions → Secrets as NEXT_PUBLIC_APP_URL
# for Twilio SMS links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: server-only account deletion (never prefix with NEXT_PUBLIC_).
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe (server-only except NEXT_PUBLIC_APP_URL already set above)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PREMIUM_MONTHLY=price_...
# STRIPE_PRICE_LISTING_BOOST=price_...

# Supabase Edge Functions (set in Dashboard → Edge Functions → Secrets, not in Next):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# WEBHOOK_SECRET=            # optional; send as x-webhook-secret on DB webhooks
# SEND_RATING_INAPP=true     # optional; inserts notification row when rated user has profile phone
